# ====================================
# BossolutionAI Backend Configuration
# ====================================

# =====================================
# Firebase Configuration
# =====================================
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id

# =====================================
# AI API Keys
# =====================================
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
GOOGLE_API_KEY=your-google-gemini-api-key
TAVILY_API_KEY=tvly-your-tavily-api-key

# =====================================
# Email Notifications - Gmail SMTP (Recommended)
# =====================================
# 📧 See EMAIL_SETUP_GUIDE.md for detailed setup instructions
# ✅ Free, no domain required, works worldwide!

# Gmail SMTP (Most common - recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=abcdefghijklmnop
SMTP_FROM_EMAIL=your.email@gmail.com
SMTP_FROM_NAME=BossolutionAI
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Alternative: Gmail with SSL (port 465)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your.email@gmail.com
# SMTP_PASSWORD=abcdefghijklmnop
# SMTP_FROM_EMAIL=your.email@gmail.com
# SMTP_FROM_NAME=BossolutionAI
# SMTP_USE_TLS=false
# SMTP_USE_SSL=true

# Alternative: Brevo (formerly Sendinblue) - Free 300 emails/day
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-email@example.com
# SMTP_PASSWORD=your-brevo-smtp-key
# SMTP_FROM_EMAIL=your-brevo-email@example.com
# SMTP_FROM_NAME=BossolutionAI
# SMTP_USE_TLS=true

# Alternative: Mailgun Sandbox - Free 100 emails/day
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@sandboxXXXXX.mailgun.org
# SMTP_PASSWORD=your-mailgun-password
# SMTP_FROM_EMAIL=noreply@sandboxXXXXX.mailgun.org
# SMTP_FROM_NAME=BossolutionAI
# SMTP_USE_TLS=true

# =====================================
# Social Media API Tokens (Optional)
# =====================================
FACEBOOK_API_TOKEN=your-facebook-api-token
INSTAGRAM_API_TOKEN=your-instagram-api-token
LINKEDIN_API_TOKEN=your-linkedin-api-token
TWITTER_API_KEY=your-twitter-api-key

# =====================================
# Server Settings
# =====================================
DEBUG=false
HOST=127.0.0.1
PORT=8000
ENVIRONMENT=development

# =====================================
# Upload Settings
# =====================================
UPLOAD_DIR=temp_uploads

# =====================================
# REMOVED: SendGrid (use SMTP instead)
# =====================================
# SENDGRID_API_KEY=removed-use-smtp-instead
# SENDGRID_FROM_EMAIL=removed-use-smtp-instead
# SENDGRID_FROM_NAME=removed-use-smtp-instead
# 
# Why removed?
# - SendGrid requires domain verification
# - Not available in all regions
# - Gmail SMTP is free, easier, and works worldwide
